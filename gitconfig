# vim: set ft=gitconfig: #
[color "diff"]
    old = red strike
    new = green italic
[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
[user]
    name = Cameron Sowder
    email = cameron@sowder.io
[core]
    editor = nvim
[instaweb]
    local = true
    httpd = webrick
    browser = open
[alias]
    lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
[difftool]
    prompt = false
[mergetool]
    prompt = false
[gui]
    fontdiff = -family \"Operator Mono for Powerline\" -size 12 -weight normal -slant roman -underline 0 -overstrike 0
    tabsize = 4
[commit]
    template = ~/.commit.template
[help]
    autoCorrect = -1
[pull]
    ff = only
[push]
    default = current
    followTags = true
[log]
    abbrevCommit = true
    decorate = short
[apply]
    ignoreWhitespace = change
[rerere]
    enabled = true
    autoUpdate = true
[am]
    threeWay = true
[color "dif"]
    old = red strike
[color]
    ui = true
[init]
    defaultBranch = master
[includeIf "gitdir:/Users/sowderca/Developer/"]
    path = ~/.dotfiles/macOS.gitconfig
[includeIf "gitdir:/home/sowderca/Developer/"]
    path = ~/.dotfiles/linux.gitconfig
[http]
    lowSpeedLimit = 1000
    lowSpeedTime = 60
    postBuffer = 524288000
